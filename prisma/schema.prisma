generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid()) @map("id")
  firstName        String            
  lastName         String            
  email            String            @unique @map("email")
  mobileNumber     String?           @map("mobile_number")
  password         String?
  role             UserRole          @default(CLIENT) @map("role")
  isEmailVerified  Boolean           @default(false) @map("is_email_verified")
  isMobileVerified Boolean           @default(false) @map("is_mobile_verified")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  profilePhoto     String?           @map("profile_photo")

  clientProfile    ClientProfile?
  therapistProfile TherapistProfile?
  ClientAssesment  ClientAssesment[]
  testimonials     Testimonial[]

  commissionRates  CommissionRate[]  @relation("UserToCommissionRates")

  lastLogin        DateTime          @default(now()) @map("last_login")    

  emailBlasts      EmailBlastLog[]  @relation("EmailBlastInitiated")

  messages         Message[]        @relation("UserMessages")

  authProvider     AuthProvider     @default(LOCAL) @map("auth_provider")
  googleAuthId     String?          @unique @map("google_auth_id")
  googleEmail      String?          @map("google_email")


  @@map("users")
  @@index([email])
}

enum AuthProvider {
  LOCAL
  GOOGLE
  HYBRID
}

enum UserRole {
  CLIENT
  THERAPIST
  ADMIN
}

model ClientProfile {
  id                     String               @id @default(uuid()) @map("id")
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String               @unique @map("user_id")

  ageGroup               AgeGroup?            @map("age_group")
  genderIdentity         GenderIdentity?      @map("gender_identity")
  occupation             Occupation?          
  seekingSupportFor      SeekingSupportFor?    @map("seeking_support_for")
  relationShipStatus     RelationShipStatus?   @map("relation_ship_status")

  //bookings
  bookings               Booking[]   
  
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@map("client_profiles")
}


enum AgeGroup {
  UNDER_18
  AGE_18_24
  AGE_25_34
  AGE_35_44
  AGE_45_54
  AGE_55_PLUS
}

enum GenderIdentity {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum Occupation {
  STUDENT
  WORKING_PROFESSIONAL
  SELF_EMPLOYED
  HOMEMAKER
  RETIRED
  NOT_WORKING
  OTHER
}

enum PrimaryObjective {
  IMPROVE_EMOTIONAL_WELL_BEING
  MANAGE_STRESS_OR_ANXIETY
  BUILD_HEALTHIER_RELATIONSHIPS
  IMPROVE_FOCUS_AND_MOTIVATION
  EXPLORE_PERSONAL_GROWTH
  NOT_SURE_JUST_WANT_TO_TALK
}

enum PriorTherapyExperience {
  YES_CURRENTLY
  YES_NOT_CURRENTLY
  NO_FIRST_TIME
}

enum PreferredSupportType {
  ONE_ON_ONE_COUNSELLING
  GROUP_WORKSHOPS
  SELF_HELP_RESOURCES
  NOT_SURE_OPEN
}

enum RelationShipStatus{
  SINGLE
  IN_A_RELATIONSHIP
  MARRIED
  SEPERATED_DIVORCED
  WIDOWED
  PREFER_NOT_TO_SAY
}

enum SeekingSupportFor {
  MYSELF
  COUPLE
  FAMILY
}


model TherapistProfile {
  id                                   String            @id @default(uuid()) @map("id")
  userId                               String            @unique @map("user_id")
  user                                 User              @relation(fields: [userId], references: [id])

  professionalTitle                    String            @map("professional_title")
  highestQualification                 String            @map("highest_qualification")
  graduationYear                       String            @map("graduation_year")
  licenseNumber                        String            @map("license_number")
  licensingAuthority                   String            @map("licensing_authority")
  yearOfExperience                     String            @map("year_of_experience")  
  languageSpoken                       String[]          @map("language_spoken")
  currentWorkspace                     String            @map("current_workspace")
  practiceType                         String            @map("practice_type")

  sessionFee                           Decimal?          @map("session_fee")
  currency                             String?           @default("INR")

  bgvConsent                           Boolean           @default(false) @map("bgv_consent")

  registrationCert                     String?           @map("registration_certificate")
  degreeCert                           String?           @map("degree_certificate")
  governmentId                         String?           @map("government_id")
  addressProof                         String?           @map("address_proof")

  about                                String?
  successStories                       String?           @map("success_stories")

  geniuneDocumentConsent               Boolean           @default(false) @map("geniune_document_consent")
  ethicalAndConfidentialityConsent     Boolean           @default(false) @map("ethical_and_confidentiality_consent")
  serviceAndPrivacyPolicyConsent       Boolean           @default(false) @map("service_and_privacy_policy_consent")

  status                               TherapistStatus   @default(PENDING) @map("status")
  rejectionReason                      String?           @map("rejection_reason")
  approvedAt                           DateTime?         @map("approved_at")
  createdAt                            DateTime          @default(now()) @map("created_at")
  updatedAt                            DateTime          @updatedAt @map("updated_at")

  slug                                 String?            @unique @map("slug")

  // relationships
  categories                           Category[]        @relation("TherapistCategories")
  subCategories                        SubCategory[]     @relation("TherapistSubCategories")

  //availability
  availability    TherapistAvailability[]

  //testimonials
  testimonials                         Testimonial[]

  //bookings
  bookings                             Booking[]    

  //UPI VPA details
  upiVpaEnc                            Bytes?
  upiVpaIv                             Bytes?
  upiVpaTag                            Bytes?
  upiVpaHash                           String?          @db.VarChar(64)
  keyVersion                           Int?             
  upiVerifiedAt                        DateTime?
  upiNameAtBank                        String?     

  googleUserId                         String?          @map("google_user_id")
  googleEmail                          String?          @map("google_email")

  accessToken                          String?           @map("access_token")
  refreshToken                         String?           @map("refresh_token")
  expiryDate                           DateTime?        @map("expiry_date") // when accessToken expires

  calendarId                           String?          @map("calendar_id")

  slots                                AvailabilitySlot[]

  @@map("therapist_profiles")
}


enum TherapistStatus {
  PENDING
  APPROVED
  REJECTED
}

model OTPVerification {
  id         String   @id @default(uuid()) @map("id")
  email      String   @map("email")
  otp        String   @map("otp")
  expiresAt  DateTime @map("expires_at")
  verified   Boolean  @default(false) @map("verified")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("otp_verifications")
  @@index([email])
}

model Category {
  id            String            @id @default(uuid()) @map("id")
  name          String            @unique
  description   String?
  subCategories SubCategory[]     @relation("CategorySubCategories")
  therapists    TherapistProfile[] @relation("TherapistCategories")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt      @map("updated_at")

  iconUrl       String?           @map("icon_url")
  slug          String?            @unique @map("slug")
  tagline       String?       
  websiteDesc   String?    



  @@map("categories")
}

model SubCategory {
  id            String            @id @default(uuid()) @map("id")
  name          String
  description   String?
  categoryId    String            @map("category_id")
  category      Category          @relation("CategorySubCategories", fields: [categoryId], references: [id])
  therapists    TherapistProfile[] @relation("TherapistSubCategories")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt      @map("updated_at")

  iconUrl       String?           @map("icon_url")
  slug          String?            @unique @map("slug")
  tagline       String?
  websiteDesc   String?


  @@map("sub_categories")
}

model TherapistAvailability {
  id                String                      @id @default(uuid())
  therapistId       String                      @map("therapist_id")
  therapist         TherapistProfile            @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  
  dayOfWeek         DayOfWeek                   @map("day_of_week")
  startTime         String                      @map("start_time") // Format: "HH:mm" (24-hour)
  endTime           String                      @map("end_time")   // Format: "HH:mm" (24-hour)
  slotDuration      Int                         @default(60) @map("slot_duration") // Duration in minutes
  
  isActive          Boolean                     @default(true) @map("is_active")
  effectiveFrom     DateTime                    @default(now()) @map("effective_from")
  effectiveTo       DateTime?                   @map("effective_to")
  
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  
  slots             AvailabilitySlot[]
  version           Int                         @default(1)


  @@index([therapistId, isActive])
  @@index([dayOfWeek])
  @@map("therapist_availability")
}

model AvailabilitySlot {
  id                    String                  @id @default(uuid())
  availabilityId        String                  @map("availability_id")
  availability          TherapistAvailability   @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  
  therapistId           String                  @map("therapist_id")
  therapist             TherapistProfile        @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  
  startDateTime         DateTime                @map("start_date_time")
  endDateTime           DateTime                @map("end_date_time")
  
  status                SlotStatus              @default(AVAILABLE)
  
  // If booked
  clientId              String?                 @map("client_id")
  booking               Booking[]                
  
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  @@unique([therapistId, startDateTime])
  @@index([therapistId, status, startDateTime])
  @@index([startDateTime, status])
  @@index([clientId])
  @@map("availability_slots")
}

model Booking {
  id                String                @id @default(uuid())
  clientId          String                @map("client_id")
  therapistId       String                @map("therapist_id")

  client            ClientProfile         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  therapist         TherapistProfile      @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  
  slotId            String                @map("slot_id")
  slot              AvailabilitySlot     @relation(fields: [slotId], references: [id])
  
  startDateTime     DateTime              @map("start_date_time")
  endDateTime       DateTime              @map("end_date_time")
  
  status            BookingStatus         @default(PENDING_PAYMENT)
  
  sessionNotes      String?               @map("session_notes")
  cancellationReason String?              @map("cancellation_reason")
  cancelledBy       String?               @map("cancelled_by")
  cancelledAt       DateTime?             @map("cancelled_at")
  
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  testimonial       Testimonial?          @relation()

  payment           Payment?              
  paymentStatus     PaymentStatus?        @map("payment_status")

  meetingLink      String?                @map("meeting_link")
  calendarEventId  String?                @map("calendar_event_id")
  meetingProvider  String?                @map("meeting_provider") // e.g. 'GOOGLE_MEET'

  conversation   Conversation?
  
  isActive          Boolean               @default(true) @map("is_active")

  @@unique([slotId, isActive], name: "unique_active_slot_booking")
  @@index([clientId, status])
  @@index([therapistId, status])
  @@index([startDateTime])
  @@map("bookings")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  COMPLETED
  CANCELLED
  HELD
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING_PAYMENT
}

model ClientAssesment {
  id                     String               @id @default(uuid()) @map("id")
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String               @map("user_id")

  recentFeeling          String?               @map("recent_feeling")
  crowdedWithWorries     String?               @map("crowded_with_worries")
  roomFullWithPeople     String?               @map("room_full_with_people")          
  dailyTaskFeeling       String?               @map("daily_task_feeling")
  thoughtEcho            String?               @map("thought_echo")
  decision               String?  
  oldMemories            String?               @map("old_memories")
  lossOrSeperation       String?               @map("loss_or_seperation")
  closestRelationShip    String?               @map("closest_relation_ship")
  sayingNo               String?               @map("saying_no")
  nightSleep             String?               @map("night_sleep")
  eatingPattern          String?               @map("eating_pattern")
  heavyLifeCope          String?               @map("heavy_life_cope")
  technologyView         String?               @map("technology_view")
  selfImage              String?               @map("self_image")
  futurePerspective      String?               @map("future_perspective")
  sucidalThoughts        String?               @map("sucidal_thoughts")
  halucinations          String? 
  selfHarm               String?               @map("self_harm")


  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@map("client_assessments")
}

model Testimonial {
  id             String           @id @default(uuid())

  therapistId    String           @map("therapist_id")
  therapist      TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  clientId       String           @map("client_id")
  client         User             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  bookingId      String           @unique @map("booking_id")
  booking        Booking?         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  rating         Int              @default(5)
  text           String?

  createdAt      DateTime         @default(now()) @map("created_at")

  @@unique([therapistId, clientId]) 
  @@map("testimonials")
}


model Payment {
  id               String    @id @default(uuid())
  razorpayPaymentId String?   @unique @map("razorpay_payment_id")
  razorpayOrderId   String?   @map("razorpay_order_id")
  bookingId         String?   @unique @map("booking_id")
  booking           Booking?  @relation(fields: [bookingId], references: [id])
  
  // canonical amount fields 
  amount            Decimal   @map("amount") // in smallest currency unit (paise)
  amountPaise       Int?      @map("amount_paise")
  currency          String    @default("INR")

  // Status Fields
  status            PaymentStatus @default(PENDING) // PENDING, AUTHORIZED, CAPTURED, FAILED, REFUNDED
  method            String?   @map("method")
  capturedAt        DateTime? @map("captured_at")
  refundedAt        DateTime? @map("refunded_at")
  rawPayload        Json?     @map("raw_payload") // store webhook payload for audits
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Fees / Snapshots of commission at time of payment
  commissionRateId    String?   @map("commission_rate_id")
  commissionRate      CommissionRate? @relation("CommissionRateToPayment", fields: [commissionRateId], references: [id])
  platformPercent     Decimal?  @map("platform_percent")   // e.g. 15.0
  gatewayPercent      Decimal?  @map("gateway_percent")    // e.g. 2.2
  
  platformFeePaise    Int?      @map("platform_fee_paise") // platform fee
  gatewayFeePaise     Int?      @map("gateway_fee_paise")  // razorpay fee
  payoutAmountPaise   Int?      @map("payout_amount_paise")// amount to therapist
  feeBreakdown        Json?     @map("fee_breakdown")      // JSON for extra details

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

model CommissionRate {
  id                 String     @id @default(uuid())
  name               String?            // e.g. "Default v1"
  platformPercent    Decimal    @map("platform_percent")// e.g. 15.0
  gatewayPercent     Decimal    @map("gateway_percent")         // e.g. 2.2
  effectiveFrom      DateTime   @map("effective_from") @default(now())
  effectiveTo        DateTime?  @map("effective_to")          // null = still active
  createdAt          DateTime   @default(now()) @map("created_at")
  adminId            String     @map("admin_id")

  admin              User       @relation("UserToCommissionRates", fields: [adminId], references: [id], onDelete: Cascade)

  payments           Payment[]  @relation("CommissionRateToPayment")

  

  @@map("commission_rates")
  @@index([effectiveFrom])
}

model EmailBlastLog {
  id                 String     @id @default(uuid())
  reason             String?    
  carriedFor         String?    @map("carried_for")   
  totalEmailSent     Int        @default(0) @map("total_email_sent")
  initiatedAt        DateTime   @default(now()) @map("initiated_at")
  adminId            String     @map("admin_id")

  admin              User       @relation("EmailBlastInitiated", fields: [adminId], references: [id], onDelete: Cascade)

  subject            String
  content            String     
  singleEmail        String?    @map("single_email")

  @@map("email_blast_logs")
}

model Conversation {
  id             String    @id @default(uuid())
  bookingId      String?   @unique @map("booking_id")
  booking        Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  clientId       String?   @map("client_id")
  therapistId    String?   @map("therapist_id")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastMessageAt  DateTime? @map("last_message_at")

  messages       Message[]

  clientLastReadAt    DateTime?  @map("client_last_read_at")
  therapistLastReadAt DateTime?  @map("therapist_last_read_at")


  @@index([clientId])
  @@index([therapistId])
  @@map("conversations")
}

enum MessageType {
  TEXT
  LINK
  FILE
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String       @map("sender_id")
  sender         User         @relation("UserMessages",fields: [senderId], references: [id], onDelete: Cascade)

  type           MessageType  @default(TEXT)
  content        String?      
  meta           Json?        

  createdAt      DateTime     @default(now()) @map("created_at")

  attachments    Attachment[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Attachment {
  id         String   @id @default(uuid())
  messageId  String   @map("message_id")
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  url        String  
  filename   String
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([messageId])
  @@map("attachments")
}
