generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid()) @map("id")
  firstName        String
  lastName         String
  email            String            @unique @map("email")
  mobileNumber     String?           @map("mobile_number")
  password         String?
  role             UserRole          @default(CLIENT) @map("role")
  isEmailVerified  Boolean           @default(false) @map("is_email_verified")
  isMobileVerified Boolean           @default(false) @map("is_mobile_verified")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  clientProfile    ClientProfile?
  therapistProfile TherapistProfile?

  @@map("users")
  @@index([email])
}

enum UserRole {
  CLIENT
  THERAPIST
  ADMIN
}

model ClientProfile {
  id                     String               @id @default(uuid()) @map("id")
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String               @unique @map("user_id")

  ageGroup               AgeGroup?            @map("age_group")
  genderIdentity         GenderIdentity?      @map("gender_identity")
  occupation             Occupation?          
  primaryObjective       PrimaryObjective?    @map("primary_objective")
  priorTherapyExperience PriorTherapyExperience? @map("prior_therapy_experience")
  preferredSupportType   PreferredSupportType?   @map("preferred_support_type")

  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@map("client_profiles")
}


enum AgeGroup {
  UNDER_18
  AGE_18_24
  AGE_25_34
  AGE_35_44
  AGE_45_54
  AGE_55_PLUS
}

enum GenderIdentity {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum Occupation {
  STUDENT
  WORKING_PROFESSIONAL
  SELF_EMPLOYED
  HOMEMAKER
  RETIRED
  NOT_WORKING
}

enum PrimaryObjective {
  IMPROVE_EMOTIONAL_WELL_BEING
  MANAGE_STRESS_OR_ANXIETY
  BUILD_HEALTHIER_RELATIONSHIPS
  IMPROVE_FOCUS_AND_MOTIVATION
  EXPLORE_PERSONAL_GROWTH
  NOT_SURE_JUST_WANT_TO_TALK
}

enum PriorTherapyExperience {
  YES_CURRENTLY
  YES_NOT_CURRENTLY
  NO_FIRST_TIME
}

enum PreferredSupportType {
  ONE_ON_ONE_COUNSELLING
  GROUP_WORKSHOPS
  SELF_HELP_RESOURCES
  NOT_SURE_OPEN
}


model TherapistProfile {
  id               String            @id @default(uuid()) @map("id")
  userId           String            @unique @map("user_id")
  user             User              @relation(fields: [userId], references: [id])

  specialization   String[]
  educationDocs    String[]          @map("education_docs") // S3 URLs
  medicalDocs      String[]          @map("medical_docs")
  experienceYears  Int?              @map("experience_years")
  about            String?
  status           TherapistStatus   @default(PENDING) @map("status")
  rejectionReason  String?           @map("rejection_reason")
  approvedAt       DateTime?         @map("approved_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  // categories and subcategories relationship
  categories       Category[]        @relation("TherapistCategories")
  subCategories    SubCategory[]     @relation("TherapistSubCategories")

  @@map("therapist_profiles")
}

enum TherapistStatus {
  PENDING
  APPROVED
  REJECTED
}

model OTPVerification {
  id         String   @id @default(uuid()) @map("id")
  email      String   @map("email")
  otp        String   @map("otp")
  expiresAt  DateTime @map("expires_at")
  verified   Boolean  @default(false) @map("verified")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("otp_verifications")
  @@index([email])
}

model Category {
  id            String            @id @default(uuid()) @map("id")
  name          String            @unique
  description   String?
  subCategories SubCategory[]     @relation("CategorySubCategories")
  therapists    TherapistProfile[] @relation("TherapistCategories")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt      @map("updated_at")

  @@map("categories")
}

model SubCategory {
  id            String            @id @default(uuid()) @map("id")
  name          String
  description   String?
  categoryId    String            @map("category_id")
  category      Category          @relation("CategorySubCategories", fields: [categoryId], references: [id])
  therapists    TherapistProfile[] @relation("TherapistSubCategories")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt      @map("updated_at")

  @@map("sub_categories")
}