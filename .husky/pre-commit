#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Format staged TS, JS, and JSON files using Prettier
staged_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|js|json)$' || true)

if [ -n "$staged_files" ]; then
  echo "Formatting staged files with Prettier..."
  npx prettier --write $staged_files
  git add $staged_files
fi

echo "Running tests..."
npm test

echo "Verifying production build..."
npm run build
