generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid()) @map("id")
  firstName        String            
  lastName         String            
  email            String            @unique @map("email")
  mobileNumber     String?           @map("mobile_number")
  password         String?
  role             UserRole          @default(CLIENT) @map("role")
  isEmailVerified  Boolean           @default(false) @map("is_email_verified")
  isMobileVerified Boolean           @default(false) @map("is_mobile_verified")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  profilePhoto     String?           @map("profile_photo")

  clientProfile    ClientProfile?
  therapistProfile TherapistProfile?
  ClientAssesment  ClientAssesment[]

  commissionRates  CommissionRate[]  @relation("UserToCommissionRates")

  lastLogin        DateTime          @default(now()) @map("last_login")    

  emailBlasts      EmailBlastLog[]  @relation("EmailBlastInitiated")

  messages         Message[]        @relation("UserMessages")

  authProvider     AuthProvider     @default(LOCAL) @map("auth_provider")
  googleAuthId     String?          @unique @map("google_auth_id")
  googleEmail      String?          @map("google_email")
  
  orgPlansCreated     OrgPlan[]           @relation("AdminOrgPlans")
  orgMemberships      OrgMember[]         @relation("UserOrgMemberships")
  orgInvitationsSent  OrgInvitation[]     @relation("UserOrgInvitations")
  
  customPlanRequests  CustomPlanRequest[] @relation("AdminCustomPlanRequests")

  orgsPaymentMarked   OrgPayment[]        @relation("AdminMarkedOrgPayments")

  ventSessions        VentSession[]
  ventMemory          UserVentMemory?

  isExtensionUser     Boolean           @default(false) @map("is_extension_user")
  accountType         AccountType       @default(PLATFORM) @map("account_type")

   extensionUsage    ExtensionUsage?
  
  @@map("users")
  @@index([email])
}

enum AccountType {
  EXTENSION_ONLY    // signed up via extension, no platform profile yet
  PLATFORM          // signed up via platform directly  
  FULL              // has both — either upgraded or was platform user who used extension
}


enum AuthProvider {
  LOCAL
  GOOGLE
  HYBRID
}

enum UserRole {
  CLIENT
  THERAPIST
  ADMIN
  ORG_ADMIN
  HR_MANAGER
  EMPLOYEE
  STUDENT
}

model ClientProfile {
  id                     String               @id @default(uuid()) @map("id")
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String               @unique @map("user_id")

  ageGroup               AgeGroup?            @map("age_group")
  genderIdentity         GenderIdentity?      @map("gender_identity")
  occupation             Occupation?          
  seekingSupportFor      SeekingSupportFor?    @map("seeking_support_for")
  relationShipStatus     RelationShipStatus?   @map("relation_ship_status")

  //bookings
  bookings               Booking[]   

  testimonials           Testimonial[]

  programPurchase        ProgramPurchase[]

  
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@map("client_profiles")
}


enum AgeGroup {
  UNDER_18
  AGE_18_24
  AGE_25_34
  AGE_35_44
  AGE_45_54
  AGE_55_PLUS
}

enum GenderIdentity {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum Occupation {
  STUDENT
  WORKING_PROFESSIONAL
  SELF_EMPLOYED
  HOMEMAKER
  RETIRED
  NOT_WORKING
  OTHER
}

enum PrimaryObjective {
  IMPROVE_EMOTIONAL_WELL_BEING
  MANAGE_STRESS_OR_ANXIETY
  BUILD_HEALTHIER_RELATIONSHIPS
  IMPROVE_FOCUS_AND_MOTIVATION
  EXPLORE_PERSONAL_GROWTH
  NOT_SURE_JUST_WANT_TO_TALK
}

enum PriorTherapyExperience {
  YES_CURRENTLY
  YES_NOT_CURRENTLY
  NO_FIRST_TIME
}

enum PreferredSupportType {
  ONE_ON_ONE_COUNSELLING
  GROUP_WORKSHOPS
  SELF_HELP_RESOURCES
  NOT_SURE_OPEN
}

enum RelationShipStatus{
  SINGLE
  IN_A_RELATIONSHIP
  MARRIED
  SEPERATED_DIVORCED
  WIDOWED
  PREFER_NOT_TO_SAY
}

enum SeekingSupportFor {
  MYSELF
  COUPLE
  FAMILY
}


model TherapistProfile {
  id                                   String            @id @default(uuid()) @map("id")
  userId                               String            @unique @map("user_id")
  user                                 User              @relation(fields: [userId], references: [id])

  professionalTitle                    String            @map("professional_title")
  highestQualification                 String            @map("highest_qualification")
  graduationYear                       String            @map("graduation_year")
  licenseNumber                        String            @map("license_number")
  licensingAuthority                   String            @map("licensing_authority")
  yearOfExperience                     String            @map("year_of_experience")  
  languageSpoken                       String[]          @map("language_spoken")
  currentWorkspace                     String            @map("current_workspace")
  practiceType                         String            @map("practice_type")

  sessionFee                           Decimal?          @map("session_fee")
  currency                             String?           @default("INR")

  bgvConsent                           Boolean           @default(false) @map("bgv_consent")

  registrationCert                     String?           @map("registration_certificate")
  degreeCert                           String?           @map("degree_certificate")
  governmentId                         String?           @map("government_id")
  addressProof                         String?           @map("address_proof")

  about                                String?
  successStories                       String?           @map("success_stories")

  geniuneDocumentConsent               Boolean           @default(false) @map("geniune_document_consent")
  ethicalAndConfidentialityConsent     Boolean           @default(false) @map("ethical_and_confidentiality_consent")
  serviceAndPrivacyPolicyConsent       Boolean           @default(false) @map("service_and_privacy_policy_consent")

  status                               TherapistStatus   @default(PENDING) @map("status")
  rejectionReason                      String?           @map("rejection_reason")
  approvedAt                           DateTime?         @map("approved_at")
  createdAt                            DateTime          @default(now()) @map("created_at")
  updatedAt                            DateTime          @updatedAt @map("updated_at")

  slug                                 String?            @unique @map("slug")

  // relationships
  categories                           Category[]        @relation("TherapistCategories")
  subCategories                        SubCategory[]     @relation("TherapistSubCategories")

  //availability
  availability    TherapistAvailability[]

  //testimonials
  testimonials                         Testimonial[]

  //bookings
  bookings                             Booking[]    

  //UPI VPA details
  upiVpaEnc                            Bytes?
  upiVpaIv                             Bytes?
  upiVpaTag                            Bytes?
  upiVpaHash                           String?          @db.VarChar(64)
  keyVersion                           Int?             
  upiVerifiedAt                        DateTime?
  upiNameAtBank                        String?     

  googleUserId                         String?          @map("google_user_id")
  googleEmail                          String?          @map("google_email")

  accessToken                          String?           @map("access_token")
  refreshToken                         String?           @map("refresh_token")
  expiryDate                           DateTime?        @map("expiry_date") // when accessToken expires

  calendarId                           String?          @map("calendar_id")

  slots                                AvailabilitySlot[]

  programs                            Program[]

  ratingSummary                       TherapistRating?    

  programPurchase                     ProgramPurchase[]

  webinars                            Webinar[]


  @@map("therapist_profiles")
}


enum TherapistStatus {
  PENDING
  APPROVED
  REJECTED
  ON_HOLD
}

model OTPVerification {
  id         String   @id @default(uuid()) @map("id")
  email      String   @map("email")
  otp        String   @map("otp")
  expiresAt  DateTime @map("expires_at")
  verified   Boolean  @default(false) @map("verified")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("otp_verifications")
  @@index([email])
}

model Category {
  id            String            @id @default(uuid()) @map("id")
  name          String            @unique
  description   String?
  subCategories SubCategory[]     @relation("CategorySubCategories")
  therapists    TherapistProfile[] @relation("TherapistCategories")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt      @map("updated_at")

  iconUrl       String?           @map("icon_url")
  slug          String?            @unique @map("slug")
  tagline       String?       
  websiteDesc   String?    



  @@map("categories")
}

model SubCategory {
  id            String            @id @default(uuid()) @map("id")
  name          String
  description   String?
  categoryId    String            @map("category_id")
  category      Category          @relation("CategorySubCategories", fields: [categoryId], references: [id])
  therapists    TherapistProfile[] @relation("TherapistSubCategories")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt      @map("updated_at")

  iconUrl       String?           @map("icon_url")
  slug          String?            @unique @map("slug")
  tagline       String?
  websiteDesc   String?


  @@map("sub_categories")
}

model TherapistAvailability {
  id                String                      @id @default(uuid())
  therapistId       String                      @map("therapist_id")
  therapist         TherapistProfile            @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  
  dayOfWeek         DayOfWeek                   @map("day_of_week")
  startTime         String                      @map("start_time") // Format: "HH:mm" (24-hour)
  endTime           String                      @map("end_time")   // Format: "HH:mm" (24-hour)
  slotDuration      Int                         @default(60) @map("slot_duration") // Duration in minutes
  
  isActive          Boolean                     @default(true) @map("is_active")
  effectiveFrom     DateTime                    @default(now()) @map("effective_from")
  effectiveTo       DateTime?                   @map("effective_to")
  
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  
  slots             AvailabilitySlot[]
  version           Int                         @default(1)


  @@index([therapistId, isActive])
  @@index([dayOfWeek])
  @@map("therapist_availability")
}

model AvailabilitySlot {
  id                    String                  @id @default(uuid())
  availabilityId        String                  @map("availability_id")
  availability          TherapistAvailability   @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  
  therapistId           String                  @map("therapist_id")
  therapist             TherapistProfile        @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  
  startDateTime         DateTime                @map("start_date_time")
  endDateTime           DateTime                @map("end_date_time")
  
  status                SlotStatus              @default(AVAILABLE)
  
  // If booked
  clientId              String?                 @map("client_id")
  booking               Booking[]                
  
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  @@unique([therapistId, startDateTime])
  @@index([therapistId, status, startDateTime])
  @@index([startDateTime, status])
  @@index([clientId])
  @@map("availability_slots")
}

model Booking {
  id                String                @id @default(uuid())
  clientId          String                @map("client_id")
  therapistId       String                @map("therapist_id")

  client            ClientProfile         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  therapist         TherapistProfile      @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  
  slotId            String                @map("slot_id")
  slot              AvailabilitySlot     @relation(fields: [slotId], references: [id])
  
  startDateTime     DateTime              @map("start_date_time")
  endDateTime       DateTime              @map("end_date_time")
  
  status            BookingStatus         @default(PENDING_PAYMENT)
  
  sessionNotes      String?               @map("session_notes")
  cancellationReason String?              @map("cancellation_reason")
  cancelledBy       String?               @map("cancelled_by")
  cancelledAt       DateTime?             @map("cancelled_at")
  
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  testimonial       Testimonial?          

  payment           Payment?              
  paymentStatus     PaymentStatus?        @map("payment_status")

  meetingLink      String?                @map("meeting_link")
  calendarEventId  String?                @map("calendar_event_id")
  meetingProvider  String?                @map("meeting_provider") // e.g. 'GOOGLE_MEET'

  conversation   Conversation?
  
  isActive          Boolean               @default(true) @map("is_active")

  rescheduledFromId String?               @map("rescheduled_from_id")
  rescheduledAt     DateTime?             @map("rescheduled_at")

  bookingType        BookingType          @default(SINGLE)@map("booking_type")
  programPurchaseId  String?              @map("program_purchase_id")
  programPurchase    ProgramPurchase?     @relation(fields: [programPurchaseId], references: [id])

  hasClientRescheduledEarlier Boolean       @default(false) @map("has_client_rescheduled_earlier")
  hasTherapistRescheduledEarlier Boolean       @default(false) @map("has_therapist_rescheduled_earlier")

  rescheduleReason   String?                @map("reschedule_reason")
  rescheduleStatus   RescheduleStatus?      @map("reschedule_status")

  rescheduleReviewedBy String?              @map("reschedule_reviewed_by")
  rescheduleReviewedAt DateTime?            @map("reschedule_reviewed_at")
  orgSubscriptionId  String?                @map("org_subscription_id")
  orgSubscription    OrgSubscription?       @relation(fields: [orgSubscriptionId], references: [id])

  @@unique([slotId, isActive], name: "unique_active_slot_booking")
  @@index([clientId, status])
  @@index([therapistId, status])
  @@index([startDateTime])
  @@map("bookings")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  COMPLETED
  CANCELLED
  HELD
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING_PAYMENT
}

enum RescheduleStatus {
  REQUESTED
  APPROVED
  REJECTED
}

model ClientAssesment {
  id                     String               @id @default(uuid()) @map("id")
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                 String               @map("user_id")

  recentFeeling          String?               @map("recent_feeling")
  crowdedWithWorries     String?               @map("crowded_with_worries")
  roomFullWithPeople     String?               @map("room_full_with_people")          
  dailyTaskFeeling       String?               @map("daily_task_feeling")
  thoughtEcho            String?               @map("thought_echo")
  decision               String?  
  oldMemories            String?               @map("old_memories")
  lossOrSeperation       String?               @map("loss_or_seperation")
  closestRelationShip    String?               @map("closest_relation_ship")
  sayingNo               String?               @map("saying_no")
  nightSleep             String?               @map("night_sleep")
  eatingPattern          String?               @map("eating_pattern")
  heavyLifeCope          String?               @map("heavy_life_cope")
  technologyView         String?               @map("technology_view")
  selfImage              String?               @map("self_image")
  futurePerspective      String?               @map("future_perspective")
  sucidalThoughts        String?               @map("sucidal_thoughts")
  halucinations          String? 
  selfHarm               String?               @map("self_harm")


  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@map("client_assessments")
}

model Testimonial {
  id             String           @id @default(uuid())

  therapistId    String           @map("therapist_id")
  therapist      TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  clientId       String           @map("client_id")
  client         ClientProfile    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  bookingId      String           @unique @map("booking_id")
  booking        Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  rating         Float              @default(0)
  text           String?

  status         TestimonialStatus        @default(PENDING)
  isVisible      Boolean           @default(true)


  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([therapistId, status])
  @@index([clientId])
  @@map("testimonials")
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

model TherapistRating {
  therapistId   String   @id @map("therapist_id")@default(uuid())
  therapist     TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  avgRating     Float    @default(0) @map("avg_rating")
  totalRatings  Int      @default(0) @map("total_ratings")

  lastUpdatedAt DateTime @updatedAt @map("last_updated_at")

  @@map("therapist_ratings")
}




model Payment {
  id               String    @id @default(uuid())
  razorpayPaymentId String?   @unique @map("razorpay_payment_id")
  razorpayOrderId   String?   @map("razorpay_order_id")
  bookingId         String?   @unique @map("booking_id")
  booking           Booking?  @relation(fields: [bookingId], references: [id])
  
  // canonical amount fields 
  amount            Decimal   @map("amount") // in smallest currency unit (paise)
  amountPaise       Int?      @map("amount_paise")
  currency          String    @default("INR")

  // Status Fields
  status            PaymentStatus @default(PENDING) // PENDING, AUTHORIZED, CAPTURED, FAILED, REFUNDED
  method            String?   @map("method")
  capturedAt        DateTime? @map("captured_at")
  refundedAt        DateTime? @map("refunded_at")
  rawPayload        Json?     @map("raw_payload") // store webhook payload for audits
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Fees / Snapshots of commission at time of payment
  commissionRateId    String?   @map("commission_rate_id")
  commissionRate      CommissionRate? @relation("CommissionRateToPayment", fields: [commissionRateId], references: [id])
  platformPercent     Decimal?  @map("platform_percent")   // e.g. 15.0
  gatewayPercent      Decimal?  @map("gateway_percent")    // e.g. 2.2
  
  platformFeePaise    Int?      @map("platform_fee_paise") // platform fee
  gatewayFeePaise     Int?      @map("gateway_fee_paise")  // razorpay fee
  payoutAmountPaise   Int?      @map("payout_amount_paise")// amount to therapist
  feeBreakdown        Json?     @map("fee_breakdown")      // JSON for extra details

  programPlanId    String?   @map("program_plan_id")
  programPlan      ProgramPlan? @relation(fields: [programPlanId], references: [id])

  programPurchaseId   String?   @unique @map("program_purchase_id")
  programPurchase     ProgramPurchase?  @relation(fields: [programPurchaseId], references: [id])

  webinarRegistrationId String? @unique @map("webinar_registration_id")
  webinarRegistration   WebinarRegistration? @relation(fields: [webinarRegistrationId], references: [id])

  bookingType        BookingType   @default(SINGLE)@map("booking_type")

  @@map("payments")
}

enum PurchaseType{
  SINGLE
  PROGRAM
  WEBINAR
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

model CommissionRate {
  id                 String     @id @default(uuid())
  name               String?            // e.g. "Default v1"
  platformPercent    Decimal    @map("platform_percent")// e.g. 15.0
  gatewayPercent     Decimal    @map("gateway_percent")         // e.g. 2.2
  effectiveFrom      DateTime   @map("effective_from") @default(now())
  effectiveTo        DateTime?  @map("effective_to")          // null = still active
  createdAt          DateTime   @default(now()) @map("created_at")
  adminId            String     @map("admin_id")

  admin              User       @relation("UserToCommissionRates", fields: [adminId], references: [id], onDelete: Cascade)

  payments           Payment[]  @relation("CommissionRateToPayment")

  purchaseType      PurchaseType @default(SINGLE)@map("purchase_type")

  

  @@map("commission_rates")
  @@index([effectiveFrom])
}

model EmailBlastLog {
  id                 String     @id @default(uuid())
  reason             String?    
  carriedFor         String?    @map("carried_for")   
  totalEmailSent     Int        @default(0) @map("total_email_sent")
  initiatedAt        DateTime   @default(now()) @map("initiated_at")
  adminId            String     @map("admin_id")

  admin              User       @relation("EmailBlastInitiated", fields: [adminId], references: [id], onDelete: Cascade)

  subject            String
  content            String     
  singleEmail        String?    @map("single_email")

  @@map("email_blast_logs")
}

model Conversation {
  id             String    @id @default(uuid())
  bookingId      String?   @unique @map("booking_id")
  booking        Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  clientId       String?   @map("client_id")
  therapistId    String?   @map("therapist_id")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastMessageAt  DateTime? @map("last_message_at")

  messages       Message[]

  clientLastReadAt    DateTime?  @map("client_last_read_at")
  therapistLastReadAt DateTime?  @map("therapist_last_read_at")


  @@index([clientId])
  @@index([therapistId])
  @@map("conversations")
}

enum MessageType {
  TEXT
  LINK
  FILE
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String       @map("sender_id")
  sender         User         @relation("UserMessages",fields: [senderId], references: [id], onDelete: Cascade)

  type           MessageType  @default(TEXT)
  content        String?      
  meta           Json?        

  createdAt      DateTime     @default(now()) @map("created_at")

  attachments    Attachment[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Attachment {
  id         String   @id @default(uuid())
  messageId  String   @map("message_id")
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  url        String  
  filename   String
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([messageId])
  @@map("attachments")
}


model Assessment {
  id          String       @id @default(uuid())
  title       String
  description String?
  icon        String?
  poster      String?
  slug        String 
  totalTakers Int          @default(0) @map("total_takers")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  questions   AssessmentQuestion[]
  submissions AssessmentSubmission[]

  verifiedBy  String?      @map("verified_by")
  targetAudience Json?   @map("target_audience")
  guidelines      Json?    @map("guidelines")
  minTime       Int?       @map("min_time")
  maxTime       Int?       @map("max_time")
  numberOfStatements  Int? @map("number_of_statements")


  zones        AssessmentZone[]



  @@index([slug,isActive])
  @@map("assessments")
}

model AssessmentZone {
  id             String   @id @default(uuid())
  assessmentId   String   @map("assessment_id")
  key            String   // e.g. ENERGY, FEAR, ROLE_OVERLOAD
  title          String   // user-facing
  description    String?
  maxRawScore    Int      @map("max_raw_score")
  order          Int

  assessment     Assessment @relation(fields: [assessmentId], references: [id])
  questions      AssessmentQuestion[]

  @@index([assessmentId, order])
  @@map("assessment_zones")
}

model AssessmentQuestion {
  id            String   @id @default(uuid())
  assessmentId  String   @map("assessment_id")
  text          String
  order         Int
  category      String? 
  isActive      Boolean @default(true)@map("is_active")

  zoneId        String?   @map("zone_id")
  isReverse     Boolean  @default(false)@map("is_reverse")

  assessment    Assessment @relation(fields: [assessmentId], references: [id])
  options       AssessmentOption[]
  zone          AssessmentZone? @relation(fields: [zoneId], references: [id])

  @@index([isActive,order,text])
  @@map("assessment_questions")
}

model AssessmentOption {
  id          String @id @default(uuid())
  questionId  String @map("question_id")
  label       String
  weight      Int
  order       Int

  question    AssessmentQuestion @relation(fields: [questionId], references: [id])

  @@index([label,order])
  @@map("assessment_options")
}

model AssessmentSubmission {
  id            String   @id @default(uuid())
  assessmentId  String   @map("assessment_id")
  email         String
  name          String?
  assessmentIndex  Int?     @map("assessment_index")
  dominantArea  String?  @map("dominant_area")
  createdAt     DateTime @default(now())@map("created_at")

  scores          Json?    
  primaryZone     String?  @map("primary_zone")

  assessment    Assessment @relation(fields: [assessmentId], references: [id])

  @@index([email, assessmentId])
  @@map("assessment_submissions")
}


model Program {
  id               String   @id @default(uuid())
  therapistId      String   @map("therapist_id")
  therapist        TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  title            String
  description      String?
  outcome          String?          // what user will achieve
  isActive         Boolean  @default(false)

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  plans            ProgramPlan[]

  purchases        ProgramPurchase[]

  @@index([therapistId, isActive])
  @@map("programs")
}

model ProgramPlan {
  id                  String   @id @default(uuid())
  programId           String   @map("program_id")
  program             Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  name                String           // e.g. "10 Sessions"
  sessionsCount       Int              // 1, 5, 10, etc
  sessionDuration     Int              @map("session_duration") // minutes
  price          Int              @map("price")
  pricePaise          Int              @map("price_paise")
  currency            String           @default("INR")

  cadence             ProgramCadence   // WEEKLY, FLEXIBLE, BIWEEKLY
  recommendedGapDays  Int?             @map("recommended_gap_days")

  isActive            Boolean           @default(false)

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  purchases           ProgramPurchase[]

  payments            Payment[]

  @@index([programId, isActive])
  @@map("program_plans")
}

enum ProgramCadence {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  FLEXIBLE
}

enum BookingType {
  SINGLE
  PROGRAM
  WEBINAR
  ORG
}

enum ProgramPurchaseStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  CANCELLED
}

model ProgramPurchase {
  id              String   @id @default(uuid())
  clientId          String                @map("client_id")
  therapistId       String                @map("therapist_id")

  client            ClientProfile         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  therapist         TherapistProfile      @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  programId       String   @map("program_id")
  programPlanId   String   @map("program_plan_id")

  program           Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  programPlan       ProgramPlan      @relation(fields: [programPlanId], references: [id], onDelete: Cascade)

  totalSessions   Int
  usedSessions    Int      @default(0)

  status          ProgramPurchaseStatus @default(ACTIVE)

  
  payment         Payment? 

  validFrom       DateTime @default(now())
  validTill       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings        Booking[]

  @@index([clientId, status])
  @@map("program_purchases")
}

model Webinar {
  id              String   @id @default(uuid())
  therapistId     String   @map("therapist_id")
  therapist       TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  bannerUrl       String?  @map("banner_url")

  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")

  timezone        String   @default("Asia/Kolkata")

  capacity        Int?
  isPaid          Boolean  @default(false)@map("is_paid")
   price          Int      @map("price")
  pricePaise      Int      @map("price_paise")
  currency        String   @default("INR")

  status          WebinarStatus @default(DRAFT)

  meetingLink     String?  @map("meeting_link")
  meetingProvider String?  @map("meeting_provider") // GOOGLE_MEET / ZOOM

  registrationCount Int    @default(0) @map("registration_count")

  registrations     WebinarRegistration[]

  publishedAt     DateTime?  @map("published_at")
  createdAt       DateTime @default(now())@map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")


  @@index([therapistId, startTime])
  @@map("webinars")
}

enum WebinarStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum WebinarRegistrationStatus {
  PENDING_PAYMENT   // order created, awaiting Razorpay capture
  CONFIRMED         // payment captured / free webinar confirmed
  CANCELLED
  REFUNDED
}

model WebinarRegistration {
  id                String                    @id @default(uuid())
  webinarId         String                    @map("webinar_id")
  webinar           Webinar                   @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  // Guest identity — no auth required
  guestName         String                    @map("guest_name")
  guestEmail        String                    @map("guest_email")
  guestPhone        String?                   @map("guest_phone")

  status            WebinarRegistrationStatus @default(PENDING_PAYMENT)

  // Email job tracking
  confirmationSentAt DateTime?               @map("confirmation_sent_at")
  confirmationJobId  String?                 @map("confirmation_job_id")

  // Soft idempotency key so the same guest can't double-register
  // (unique on webinarId + guestEmail, only one CONFIRMED allowed — enforced at app layer)
  
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  paymentId  String?
  payment    Payment?


  @@index([webinarId, status])
  @@index([guestEmail, webinarId])
  @@map("webinar_registrations")
}


// ─── B2B ENUMS ────────────────────────────────────────────────

enum OrgType {
  CORPORATE
  SCHOOL
  COLLEGE
}

enum OrgStatus {
  PENDING_ONBOARDING
  DISCUSSION_PENDING
  IN_DISCUSSION
  PLAN_CREATED
  PAYMENT_LINK_SENT
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum OrgSubStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  PER_SEMESTER
  CUSTOM
}

enum OrgMemberRole {
  ORG_ADMIN
  HR_MANAGER
  EMPLOYEE
  STUDENT
}

enum OrgMemberStatus {
  ACTIVE
  INACTIVE
  REMOVED
}

enum OrgInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum CustomPlanRequestStatus {
  IN_DISCUSSION
  PAYMENT_LINK_SENT
  PLAN_CREATED
  REJECTED
}

// ─── B2B MODELS ───────────────────────────────────────────────

model Organization {
  id            String      @id @default(uuid())
  name          String
  slug          String      @unique
  type          OrgType     @default(CORPORATE)
  orgSize          Int?     @map("org_size")
  contactName String @map("contact_name")
  contactEmail String @map("contact_email")
  contactPhone  String @map("contact_phone")
  email         String?      
  phone         String?
  logoUrl       String?     @map("logo_url")
  website       String?
  gstNumber     String?     @map("gst_number")
  address       Json?
  status        OrgStatus   @default(PENDING_ONBOARDING)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  notes         String?     @db.Text

  setupToken          String?   @unique @map("setup_token")
  setupTokenExpiresAt DateTime? @map("setup_token_expires_at")
  setupCompletedAt    DateTime? @map("setup_completed_at")

  orgAccountTeamContactName  String?  @map("org_account_team_contact_name")
  orgAccountTeamContactEmail String?  @map("org_account_team_contact_email")

  subscriptions OrgSubscription[]
  members       OrgMember[]
  invitations   OrgInvitation[]
  customPlanReq CustomPlanRequest?

  @@map("organizations")
}

model OrgPlan {
  id                String       @id @default(uuid())
  name              String
  slug              String       @unique
  type              OrgType
  isVisible         Boolean      @default(true)
  isCustom          Boolean      @default(false) @map("is_custom")
  sessionsCount     Int          @map("sessions_count")
  maxMembers        Int          @map("max_members")
  sessionDuration   Int          @map("session_duration")
  pricePaise        Int          @map("price_paise")
  currency          String       @default("INR")
  billingCycle      BillingCycle @map("billing_cycle")
  features          Json?
  description       String?
  highlightedText   String?      @map("highlighted_text")
  isActive          Boolean      @default(true) @map("is_active")
  createdByAdminId  String       @map("created_by_admin_id")
  createdBy         User         @relation("AdminOrgPlans", fields: [createdByAdminId], references: [id])
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  subscriptions     OrgSubscription[]

  @@map("org_plans")
}

model OrgSubscription {
  id             String       @id @default(uuid())
  orgId          String       @map("org_id")
  org            Organization @relation(fields: [orgId], references: [id])
  planId         String?      @map("plan_id")
  plan           OrgPlan?     @relation(fields: [planId], references: [id])

  // Billing snapshot — frozen at purchase time
  planName       String       @map("plan_name")
  planType       OrgType      @map("plan_type")
  totalSessions  Int          @map("total_sessions")
  usedSessions   Int          @default(0) @map("used_sessions")
  maxMembers     Int          @map("max_members")
  pricePaise     Int          @map("price_paise")
  currency       String       @default("INR")
  billingCycle   BillingCycle @map("billing_cycle")
  features       Json?

  status         OrgSubStatus @default(ACTIVE)
  validFrom      DateTime     @map("valid_from")
  validTill      DateTime     @map("valid_till")
  autoRenew      Boolean      @default(false) @map("auto_renew")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  payment        OrgPayment?
  bookings       Booking[]

  customPlanRequestId  String?  @unique @map("custom_plan_request_id")
  customPlanRequest    CustomPlanRequest? @relation(fields: [customPlanRequestId], references: [id])

  sessionAllocPolicy   String   @default("POOL") @map("session_alloc_policy") // values: "POOL" | "PER_MEMBER"
  defaultSessionsPerMember Int? @map("default_sessions_per_member")

  @@index([orgId, status])
  @@map("org_subscriptions")
}

model OrgPayment {
  id                  String          @id @default(uuid())
  orgSubscriptionId   String          @unique @map("org_subscription_id")
  orgSubscription     OrgSubscription @relation(fields: [orgSubscriptionId], references: [id])
  razorpayOrderId     String?         @unique @map("razorpay_order_id")
  razorpayPaymentId   String?         @unique @map("razorpay_payment_id")
  amountPaise         Int             @map("amount_paise")
  currency            String          @default("INR")
  status              PaymentStatus   @default(PENDING)
  method              String?


  offlineReference    String?        @map("offline_reference")  // cheque no / UTR
  offlineNote         String?        @map("offline_note")
  markedPaidByAdminId String?        @map("marked_paid_by_admin_id")
  markedPaidBy        User?          @relation("AdminMarkedOrgPayments", fields: [markedPaidByAdminId], references: [id])
  markedPaidAt        DateTime?      @map("marked_paid_at")


  rawPayload          Json?           @map("raw_payload")

    // Invoice
  invoiceNumber       String?         @unique @map("invoice_number")
  invoiceUrl          String?         @map("invoice_url")
  capturedAt          DateTime?       @map("captured_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@map("org_payments")
}

model OrgMember {
  id               String          @id @default(uuid())
  orgId            String          @map("org_id")
  org              Organization    @relation(fields: [orgId], references: [id])
  userId           String          @map("user_id")
  user             User            @relation("UserOrgMemberships", fields: [userId], references: [id])
  role             OrgMemberRole   @default(EMPLOYEE)
  department       String?
  employeeCode     String?         @map("employee_code")
  sessionsUsed     Int             @default(0) @map("sessions_used")
  sessionsAllotted Int?            @map("sessions_allotted")
  status           OrgMemberStatus @default(ACTIVE)
  joinedAt         DateTime        @default(now()) @map("joined_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@unique([orgId, userId])
  @@index([orgId, status])
  @@map("org_members")
}

model OrgInvitation {
  id              String              @id @default(uuid())
  orgId           String              @map("org_id")
  org             Organization        @relation(fields: [orgId], references: [id])
  email           String
  role            OrgMemberRole       @default(EMPLOYEE)
  token           String              @unique
  expiresAt       DateTime            @map("expires_at")
  status          OrgInvitationStatus @default(PENDING)
  invitedByUserId String?              @map("invited_by_user_id")
  invitedBy       User?                @relation("UserOrgInvitations", fields: [invitedByUserId], references: [id])
  acceptedAt      DateTime?           @map("accepted_at")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@unique([orgId, email])
  @@index([token])
  @@map("org_invitations")
}

model CustomPlanRequest {
  id               String                  @id @default(uuid())
  orgId            String                  @unique @map("org_id")
  org              Organization            @relation(fields: [orgId], references: [id])
  notes            String?
  status           CustomPlanRequestStatus @default(IN_DISCUSSION)
  paymentLink       String?      @map("payment_link")
  sessionsCount     Int          @map("sessions_count")
  maxMembers        Int          @map("max_members")
  sessionDuration   Int          @map("session_duration")
  price             Int          
   pricePaise        Int                   @map("price_paise")
  currency          String                 @default("INR")
  billingCycle      BillingCycle           @map("billing_cycle")@default(ANNUAL)
  features          Json?
  description       String?
  highlightedText   String?                 @map("highlighted_text")
  assignedAdminId  String?                 @map("assigned_admin_id")
  assignedAdmin    User?                   @relation("AdminCustomPlanRequests", fields: [assignedAdminId], references: [id])
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  subscription  OrgSubscription?

  @@map("custom_plan_requests")
}

model VentSession {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt    DateTime      @default(now()) @map("started_at")
  lastActiveAt DateTime      @updatedAt @map("last_active_at")
  isActive     Boolean       @default(true) @map("is_active")
  messages     VentMessage[]

  @@index([userId, lastActiveAt(sort: Desc)])
  @@map("vent_sessions")
}

model VentMessage {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  session   VentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // "user" | "assistant"
  content   String
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("vent_messages")
}

model UserVentMemory {
  id                       String   @id @default(uuid())
  userId                   String   @unique @map("user_id")
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary                  String   @db.Text
  updatedAt                DateTime @updatedAt @map("updated_at")
  messagesSinceLastSummary Int      @default(0) @map("messages_since_last_summary")

  @@map("user_vent_memories")
}

model ExtensionUsage {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageCount    Int      @default(0) @map("message_count")
  resetAt         DateTime? @map("reset_at")  // for monthly resets on paid plans
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("extension_usage")
}

